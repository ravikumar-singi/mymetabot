# ─── Claude AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Instagram / Facebook (Meta Graph API) ───────────────────────────────────
# Get from: https://developers.facebook.com/apps/
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret

# Instagram Business Account ID
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id
# Long-lived Page Access Token (valid 60 days, refresh via token exchange)
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# Facebook Page ID and Page Access Token
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token

# ─── YouTube (Google API) ────────────────────────────────────────────────────
# Download OAuth2 credentials JSON from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_CHANNEL_ID=your_youtube_channel_id

# ─── Bot Settings ────────────────────────────────────────────────────────────
# Niche/topic for the account (e.g. "fitness", "travel", "tech", "cooking")
BOT_NICHE=lifestyle
# Brand name used in content
BOT_BRAND_NAME=MyMetaBot
# Target audience description
BOT_TARGET_AUDIENCE=young adults aged 18-35 interested in lifestyle content
# Tone of voice: professional / casual / humorous / inspirational
BOT_TONE=inspirational

# Posting schedule (cron expressions, UTC)
INSTAGRAM_POST_SCHEDULE=0 9 * * 1,3,5
FACEBOOK_POST_SCHEDULE=0 10 * * 1,3,5
YOUTUBE_POST_SCHEDULE=0 14 * * 2,4

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///mymetabot.db

# ─── Optional: Image generation ──────────────────────────────────────────────
# If you have Stability AI or DALL-E for auto image creation
STABILITY_API_KEY=
OPENAI_API_KEY=
